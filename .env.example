# ─────────────────────────────────────────────
#  Trading Webhook System - Environment Config
# ─────────────────────────────────────────────

# Server
PORT=80
NODE_ENV=production

# JWT Secret (change this to a long random string in production)
JWT_SECRET=change_this_to_a_secure_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── TOPSTEP / TRADOVATE ─────────────────────
# Topstep executes via Tradovate. Provide the base URL for live or sim.
# Live:  https://live.tradovateapi.com
# Paper: https://demo.tradovateapi.com
TRADOVATE_BASE_URL=https://demo.tradovateapi.com
TRADOVATE_APP_ID=your_tradovate_app_id
TRADOVATE_APP_VERSION=1.0

# ─── LUCID MARKETS ───────────────────────────
# Lucid Markets REST API base
LUCID_BASE_URL=https://api.lucidmarkets.com
LUCID_API_VERSION=v1

# ─── DATA STORAGE ────────────────────────────
# Path to the JSON flat-file database
DB_PATH=./data/db.json

# ─── WEBHOOK ─────────────────────────────────
# Public base URL of this server (used when generating webhook URLs to show users)
PUBLIC_BASE_URL=http://your-server-ip-or-domain

# ─── RATE LIMITING ───────────────────────────
# Max TradingView alert requests per minute per webhook token
WEBHOOK_RATE_LIMIT=60
